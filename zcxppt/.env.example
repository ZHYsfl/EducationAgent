ZCXPPT_PORT=9400
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
INTERNAL_KEY=your-internal-key
JWT_SECRET=change-me

# Upstream services
VOICE_AGENT_URL=http://localhost:9200

# Repository modes (recommend redis in production)
TASK_REPO_MODE=redis
TASK_TTL_HOURS=168
PPT_REPO_MODE=redis
FEEDBACK_REPO_MODE=redis
EXPORT_REPO_MODE=redis

# LLM runtime
LLM_RUNTIME_MODE=real
LLM_API_KEY=your-kimi-api-key
LLM_MODEL=moonshot-v1-8k
LLM_BASE_URL=https://api.moonshot.cn/v1

# OSS
OSS_PROVIDER=local
OSS_BUCKET=exports
OSS_REGION=
OSS_SECRET_ID=
OSS_SECRET_KEY=
OSS_SIGNING_KEY=
OSS_BASE_URL=http://localhost:9000
OSS_LOCAL_PATH=./data/oss
