# Server
SERVER_PORT=9000

# ASR mode: "local" (self-hosted WebSocket) or "remote" (Doubao cloud API)
ASR_MODE=remote

# ASR local mode (Fun-ASR-Nano / Qwen3-ASR WebSocket)
ASR_WS_URL=ws://localhost:10096

# ASR remote mode (Doubao 大模型流式语音识别, only needed when ASR_MODE=remote)
# Get credentials from https://console.volcengine.com/ -> 豆包语音 -> 语音识别大模型
# APP_KEY   = 控制台 "APP ID"
# ACCESS_KEY = 控制台 "Access Token"
# RESOURCE_ID: 1.0小时版 volc.bigasr.sauc.duration | 2.0小时版 volc.seedasr.sauc.duration
#              1.0并发版 volc.bigasr.sauc.concurrent | 2.0并发版 volc.seedasr.sauc.concurrent
DOUBAO_ASR_APP_KEY=6271472845
DOUBAO_ASR_ACCESS_KEY=R6qE1SoUyMBaY3U8TLbYH9p6PkchInjy
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Small LLM (interrupt detection, OpenAI-compatible API)
SMALL_LLM_API_KEY=EMPTY
SMALL_LLM_BASE_URL=http://localhost:8000/v1
SMALL_LLM_MODEL=/mnt/d/创业/myResearch/EducationAgent/models/Qwen3___5-0___8B

# Large LLM (response generation, OpenAI-compatible API)
# Small + Large share the same vLLM instance (both Qwen3.5-0.8B)
LARGE_LLM_API_KEY=EMPTY
LARGE_LLM_BASE_URL=http://localhost:8000/v1
LARGE_LLM_MODEL=/mnt/d/创业/myResearch/EducationAgent/models/Qwen3___5-0___8B

# TTS mode: "local" (self-hosted CosyVoice2) or "remote" (Doubao cloud API)
TTS_MODE=remote

# TTS local mode (CosyVoice2 FastAPI)
TTS_URL=http://localhost:50000

# TTS remote mode (Doubao 在线语音合成, only needed when TTS_MODE=remote)
# Get credentials from https://console.volcengine.com/ -> 豆包语音 -> 语音合成
# APPID = 控制台 "APP ID"
# TOKEN = 控制台 "Access Token"
DOUBAO_TTS_APPID=6271472845
DOUBAO_TTS_TOKEN=R6qE1SoUyMBaY3U8TLbYH9p6PkchInjy
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_VOICE_TYPE=zh_female_yv_uranus_bigtts

# Interactive ReAct
TOKEN_BUDGET=50
FILLER_INTERVAL=100
FILLER_PHRASE_1=好的，让我想一下
FILLER_PHRASE_2=还在想，稍等一下
FILLER_PHRASE_3=马上就好

# System prompt
SYSTEM_PROMPT=你是一个有帮助的AI教育助手，请用中文回答问题。回答时请先给一句简短回应，再展开详细解释。第一句避免长句和复杂从句。

# External service endpoints
PPT_AGENT_URL=http://localhost:9200
KB_SERVICE_URL=http://localhost:9300
MEMORY_SERVICE_URL=http://localhost:9100
SEARCH_SERVICE_URL=http://localhost:9400
DB_SERVICE_URL=http://localhost:9500

# Default user id (used in local development before auth integration)
USER_ID=user_default
