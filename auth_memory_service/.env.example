# Auth + Memory service local environment
# Copy to auth_memory_service/.env and adjust values for your machine.

# HTTP server
AUTH_MEMORY_PORT=9300

# PostgreSQL (required)
# Example for local default postgres user/db:
# POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/auth_memory_service?sslmode=disable
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/auth_memory_service?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
WORKING_MEMORY_TTL_HOURS=4

# JWT (required; must not be "change-me")
JWT_SECRET=local-dev-jwt-secret-change-this
JWT_TTL_HOURS=24

# Email verify token behavior
VERIFY_TOKEN_TTL_HOURS=24
FRONTEND_VERIFY_URL=http://localhost:3000/verify-email

# Internal service auth (required)
INTERNAL_KEY=local-internal-key-change-this
