# ==============================
# App
# ==============================
PORT=9500

# PostgreSQL DSN
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# ==============================
# PostgreSQL (docker-compose)
# ==============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ==============================
# MinIO (S3-compatible)
# ==============================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teaching-agent
MINIO_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==============================
# File delete worker
# ==============================
FILE_DELETE_MAX_RETRY=5

# ==============================
# Search provider
# provider: duckduckgo | serpapi | metaso
# ==============================
SEARCH_PROVIDER=metaso
SERPAPI_KEY=
METASO_API_KEY=
METASO_API_URL=https://metaso.cn/api/open/search

# ==============================
# Optional KB dedup (before search callback)
# ==============================
KB_DEDUP_ENABLED=false
KB_QUERY_URL=http://localhost:9200/api/v1/kb/query
KB_SCORE_THRESHOLD=0.5
