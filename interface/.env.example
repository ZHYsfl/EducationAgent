# ==============================
# App
# ==============================
PORT=9500

# PostgreSQL DSN
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# ==============================
# PostgreSQL (docker-compose)
# ==============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ==============================
# MinIO (S3-compatible)
# ==============================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teaching-agent
MINIO_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==============================
# OSS (Object Storage)
# provider: local | minio | s3
# ==============================
# Use local filesystem storage (dev-only)
OSS_PROVIDER=local
OSS_BASE_URL=http://localhost:9500
OSS_LOCAL_PATH=./storage
OSS_SIGNING_KEY=
# Allow unsigned GET /oss/* (dev-only; default false)
OSS_ALLOW_UNSIGNED=false
#
# Use MinIO/S3 (recommended)
# OSS_PROVIDER=minio
# OSS_ENDPOINT=${MINIO_ENDPOINT}
# OSS_BUCKET=${MINIO_BUCKET}
# OSS_SECRET_ID=${MINIO_ACCESS_KEY}
# OSS_SECRET_KEY=${MINIO_SECRET_KEY}
# OSS_USE_SSL=${MINIO_USE_SSL}
# Optional: override "public" storage_url base, e.g. http://127.0.0.1:9000/teaching-agent
# OSS_PUBLIC_BASE_URL=

# ==============================
# File delete worker
# ==============================
FILE_DELETE_MAX_RETRY=5

# ==============================
# Search provider
# SEARCH_PROVIDERS supports comma-separated backends run in parallel.
# - SEARCH_PROVIDERS: "metaso,duckduckgo" (parallel)
# - SEARCH_PROVIDER: legacy single backend (kept for compatibility)
# ==============================
SEARCH_PROVIDERS=metaso,duckduckgo
SEARCH_PROVIDER=metaso
SEARCH_STRATEGY=merge   # merge | first_success
SEARCH_TIMEOUT_MS=10000
SERPAPI_KEY=
METASO_API_KEY=
METASO_API_URL=https://metaso.cn/api/open/search

# ==============================
# Optional KB dedup (before search callback)
# ==============================
KB_DEDUP_ENABLED=false
KB_QUERY_URL=http://localhost:9200/api/v1/kb/query
KB_SCORE_THRESHOLD=0.5
