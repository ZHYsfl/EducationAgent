# Voice Agent Go 后端环境变量配置
# 复制本文件为 .env 后填写实际值
# 说明：本地三路 vLLM 端口约定为 8000 / 8001 / 8002（与 start_dual_voice_asr 默认不同），
# 请用环境变量或端口映射把实际服务接到这三端口后再启动 Go。
# 启动 Go 前：export $(grep -v '^#' .env | xargs) 或自行 export。

# ==============================================
# 1) Voice Agent LLM（语音助手推理服务）
# ==============================================
# 必须以 /v1 结尾 → 本机约定 **8001**
VOICE_LLM_BASE_URL=http://127.0.0.1:8001/v1

# LoRA 模块名称，须与 vLLM --lora-modules 的 name 一致
VOICE_LLM_MODEL=voice-agent

# API Key（若 vLLM 未启用 --api-key，可随便填）
VOICE_LLM_API_KEY=dummy

# ==============================================
# 2) Interrupt-Check LLM（打断检测模型）
# ==============================================
# 打断检测 → 本机约定 **8000**
INTERRUPT_LLM_BASE_URL=http://127.0.0.1:8000/v1
INTERRUPT_LLM_MODEL=interrupt-detection
INTERRUPT_LLM_API_KEY=dummy

# ==============================================
# 3) PPT Agent LLM（PPT 生成服务）
# ==============================================
# PPT Agent 调用的 LLM，用于生成 PPT 内容
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=sk-38412e4a3b4142dba99a94d22db23d70

# ==============================================
# 4) ASR（语音识别）
# ==============================================
# ASR → 本机约定 **8002**
ASR_OPENAI_BASE_URL=http://127.0.0.1:8002/v1

# ASR 模型 ID（与 vLLM serve 时 --lora-modules 或模型路径一致）
ASR_MODEL_ID=/root/autodl-tmp/asr

# ASR API Key（若未启用鉴权，可随便填）
ASR_API_KEY=EMPTY

# ==============================================
# 5) Search Service（联网搜索，可选）
# ==============================================
# 搜索 API 地址，留空则默认使用 Tavily
SEARCH_API_URL=

# Tavily API Key（使用 Tavily 搜索时必须填写）
TAVILY_API_KEY=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
